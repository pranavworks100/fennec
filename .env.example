# Fennec environment variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Required: Google Gemini / Generative Language API key (store in Actions secrets for CI)
# Get a key at: https://console.cloud.google.com/apis/credentials or provider docs
GEMINI_API_KEY=your_gemini_api_key_here

# Notes:
# - Hacker News + RSS feeds are used; no API key required for those sources.